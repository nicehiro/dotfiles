anchor=top-right
layer=overlay
width=520
height=160
margin=16
padding=18
border-size=2
border-radius=12
background-color=#212337ee
text-color=#ebfafaff
border-color=#a48cf2ff
progress-color=over #37f499ff
font=IoskeleyMono Nerd Font 20
