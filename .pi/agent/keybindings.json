{
  "tui.editor.cursorUp": [
    "up",
    "ctrl+p"
  ],
  "tui.editor.cursorDown": [
    "down",
    "ctrl+n"
  ],
  "tui.select.up": [
    "up",
    "ctrl+p"
  ],
  "tui.select.down": [
    "down",
    "ctrl+n"
  ],
  "app.model.cycleForward": [
    "ctrl+shift+p"
  ],
  "app.model.cycleBackward": [
    "ctrl+shift+alt+p"
  ],
  "app.session.toggleNamedFilter": [
    "ctrl+shift+n"
  ]
}
