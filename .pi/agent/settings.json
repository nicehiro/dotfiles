{
  "packages": [
    "https://github.com/default-anton/pi-librarian",
    "https://github.com/nicehiro/pi-relay",
    "https://github.com/davebcn87/pi-autoresearch.git",
    "npm:pi-subagents",
    "npm:pi-mcp-adapter",
    "https://github.com/nicehiro/pi-arxiv"
  ],
  "theme": "nightowl",
  "lastChangelogVersion": "0.78.0",
  "defaultProvider": "openai",
  "defaultModel": "gpt-5.5-pro",
  "hideThinkingBlock": false,
  "defaultThinkingLevel": "xhigh",
  "safeGit": {
    "enabledByDefault": true,
    "promptLevel": "medium"
  },
  "enableSkillCommands": true,
  "skills": [
    "~/.codex/skills"
  ],
  "enabledModels": [
    "openai/gpt-5.5-pro:high",
    "openai/gpt-5.5-pro:off",
    "openai/gpt-5.5-pro:xhigh",
    "anthropic/claude-sonnet-4-6:high",
    "anthropic/claude-opus-4-7:high"
  ]
}