  "enableSkillCommands": true,
  "skills": [
    "~/.codex/skills"
  ],
  "enabledModels": [
    "anthropic/claude-opus-4-6",
    "openai/gpt-5.4"
  ],
  "pi-codex-usage": {
    "usageMode": "left",
    "refreshWindow": "7d"
  }
}